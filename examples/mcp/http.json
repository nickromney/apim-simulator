{
  "allowed_origins": ["http://localhost:8000"],
  "allow_anonymous": true,
  "trace_enabled": true,
  "products": {
    "mcp": {
      "name": "MCP",
      "description": "Subscription-protected MCP example product",
      "require_subscription": true
    }
  },
  "subscription": {
    "required": true,
    "header_names": ["Ocp-Apim-Subscription-Key", "X-Ocp-Apim-Subscription-Key"],
    "subscriptions": {
      "mcp-demo": {
        "id": "sub-mcp-demo",
        "name": "mcp-demo",
        "keys": {"primary": "mcp-demo-key", "secondary": "mcp-demo-key-secondary"},
        "products": ["mcp"],
        "created_by": "publisher"
      }
    }
  },
  "routes": [
    {
      "name": "mcp-server",
      "path_prefix": "/",
      "upstream_base_url": "http://mcp-server:8080",
      "upstream_path_prefix": "",
      "product": "mcp"
    }
  ]
}
